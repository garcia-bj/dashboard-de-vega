# ============================================================
#  De Vega — Stack #2: Backend (FastAPI + n8n)
# ============================================================

# ──── Conexion a PostgreSQL (Stack #1) ────
DATABASE_URL=postgresql+asyncpg://de_vega:CAMBIA_ESTA_CONTRASEÑA@postgres:5432/de_vega

# ──── Conexion a Redis (Stack #1) ────
REDIS_URL=redis://redis:6379/0

# ──── General ────
APP_NAME=De_Vega
DEBUG=false
SECRET_KEY=GENERA_CON_openssl_rand_hex_32

# ──── Usuario admin (se crea automaticamente al iniciar si no existe) ────
ADMIN_EMAIL=tu@email.com
ADMIN_PASSWORD=tu_contraseña_segura

# ──── Storage: RustFS (servidor externo) ────
STORAGE_BACKEND=s3
STORAGE_S3_BUCKET=de-vega-media
STORAGE_S3_ENDPOINT=http://IP_RUSTFS:9000
STORAGE_S3_PUBLIC_URL=http://IP_RUSTFS:9000
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=RUSTFS_ACCESS_KEY
STORAGE_S3_SECRET_KEY=RUSTFS_SECRET_KEY

# ──── n8n externo ────
# URL completa del webhook de generacion de imagen en tu n8n
N8N_IMG_GENERATION_URL=https://TU_N8N/webhook/img_asd
# Estas se usan para el workflow de auto-publicacion (si aplica)
N8N_WEBHOOK_URL=https://TU_N8N
N8N_IMAGE_GEN_WEBHOOK=/webhook/img_asd
N8N_PUBLISH_WEBHOOK=/webhook/auto-publish

# ──── AI APIs (opcionales si n8n las maneja directamente) ────
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ──── Meta (Facebook / Instagram) ────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://TU_DOMINIO/api/social/meta/callback

# ──── CORS (separado por comas) ────
CORS_ORIGINS=https://TU_DOMINIO_FRONTEND

