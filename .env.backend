# ============================================================
#  De Vega — Stack #2: Backend (FastAPI + n8n)
#  Necesita credenciales de DB, APIs IA, Meta, n8n, CORS
# ============================================================

# ──── Conexion a PostgreSQL (Stack #1) ────
# Si deployas en el mismo servidor, usa "postgres" como host.
# Si deployas en otro servidor, usa la IP o hostname del servidor de infra.
DATABASE_URL=postgresql+asyncpg://de_vega:genera-una-contraseña-segura-aqui@postgres:5432/de_vega
POSTGRES_USER=de_vega
POSTGRES_PASSWORD=genera-una-contraseña-segura-aqui
POSTGRES_N8N_DB=n8n

# ──── Conexion a Redis (Stack #1) ────
# Mismo caso: "redis" si es local, o IP/hostname si es remoto
REDIS_URL=redis://redis:6379/0

# ──── General ────
APP_NAME=De_Vega
DEBUG=false
SECRET_KEY=genera-una-clave-de-64-caracteres-aqui

# ──── Storage ────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
# STORAGE_BACKEND=s3
# STORAGE_S3_BUCKET=de-vega-media
# STORAGE_S3_ENDPOINT=https://s3.amazonaws.com
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=TU_ACCESS_KEY
# STORAGE_S3_SECRET_KEY=TU_SECRET_KEY

# ──── n8n (interno, se comunica por red Docker) ────
N8N_WEBHOOK_URL=http://n8n:5678
N8N_IMAGE_GEN_WEBHOOK=/webhook/image-generation
N8N_PUBLISH_WEBHOOK=/webhook/auto-publish

# ──── AI APIs ────
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ──── Meta (Facebook / Instagram) ────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://TU_DOMINIO/api/social/meta/callback

# ──── CORS (separado por comas) ────
CORS_ORIGINS=http://localhost:3000,https://TU_DOMINIO

# ──── n8n publico ────
# URL publica de n8n (cambiar por tu dominio real)
N8N_EDITOR_BASE_URL=https://n8n.TU_DOMINIO.com
N8N_WEBHOOK_URL_PUBLIC=https://n8n.TU_DOMINIO.com
