# ──── General ────
APP_NAME=De_Vega
DEBUG=false
SECRET_KEY=cambia-por-una-clave-segura-de-64-caracteres

# ──── Database ────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ──── Storage ────
# Opción A: local (desarrollo sin Docker S3)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads

# Opción B: RustFS / S3-compatible
# STORAGE_BACKEND=s3
# STORAGE_S3_BUCKET=de-vega-media
# STORAGE_S3_ENDPOINT=http://rustfs:9000        # URL interna Docker (backend → RustFS)
# STORAGE_S3_PUBLIC_URL=http://localhost:9000   # URL pública (browser → RustFS)
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=de_vega
# STORAGE_S3_SECRET_KEY=de_vega_secret

# ──── n8n ────
N8N_WEBHOOK_URL=http://localhost:5678
N8N_IMAGE_GEN_WEBHOOK=/webhook/image-generation
N8N_PUBLISH_WEBHOOK=/webhook/auto-publish
N8N_IMG_GENERATION_URL=  # Full URL override (e.g. https://mi-n8n.com/webhook/img_asd)

# ──── AI APIs ────
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ──── Meta (Facebook/Instagram) ────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/social/meta/callback

# ──── Redis ────
REDIS_URL=redis://localhost:6379/0

# ──── CORS (separado por comas) ────
CORS_ORIGINS=http://localhost:3000
