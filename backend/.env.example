# ──── General ────
APP_NAME=De_Vega
DEBUG=false
SECRET_KEY=cambia-por-una-clave-segura-de-64-caracteres

# ──── Database ────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ──── Usuario admin (seed automatico al iniciar) ────
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=contraseña_segura

# ──── Storage ────
# Opción A: local (desarrollo sin Docker S3)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads

# Opción B: RustFS / S3-compatible
# STORAGE_BACKEND=s3
# STORAGE_S3_BUCKET=de-vega-media
# STORAGE_S3_ENDPOINT=http://IP_RUSTFS:9000     # URL que el backend usa para subir (interna o IP)
# STORAGE_S3_PUBLIC_URL=http://IP_RUSTFS:9000   # URL que el navegador usa para ver las imágenes
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=tu_access_key
# STORAGE_S3_SECRET_KEY=tu_secret_key

# ──── n8n ────
# URL completa del webhook de generacion (override, tiene prioridad)
N8N_IMG_GENERATION_URL=https://mi-n8n.com/webhook/img_asd
# Fallback si no se define N8N_IMG_GENERATION_URL
N8N_WEBHOOK_URL=http://n8n:5678
N8N_IMAGE_GEN_WEBHOOK=/webhook/image-generation
N8N_PUBLISH_WEBHOOK=/webhook/auto-publish

# ──── AI APIs ────
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ──── Meta (Facebook/Instagram) ────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://api.tudominio.com/api/social/meta/callback

# ──── Redis ────
REDIS_URL=redis://localhost:6379/0

# ──── CORS (separado por comas) ────
CORS_ORIGINS=http://localhost:3000
