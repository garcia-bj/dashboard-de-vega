# ──── General ────
APP_NAME=De_Vega
DEBUG=false
SECRET_KEY=cambia-por-una-clave-segura-de-64-caracteres

# ──── Database ────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ──── Storage ────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads

# ──── n8n ────
N8N_WEBHOOK_URL=http://localhost:5678
N8N_IMAGE_GEN_WEBHOOK=/webhook/image-generation
N8N_PUBLISH_WEBHOOK=/webhook/auto-publish

# ──── AI APIs ────
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ──── Meta (Facebook/Instagram) ────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/social/meta/callback

# ──── Redis ────
REDIS_URL=redis://localhost:6379/0
