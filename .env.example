# ──── General ────
APP_NAME=De_Vega
DEBUG=true
SECRET_KEY=cambia-esto-por-una-clave-segura-de-64-chars

# ──── Database ────
DATABASE_URL=postgresql+asyncpg://de_vega:de_vega_secret@postgres:5432/de_vega

# ──── Storage ────
# Opciones: "local" | "s3"
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads

# Si usas S3 en el futuro:
# STORAGE_BACKEND=s3
# STORAGE_S3_BUCKET=de-vega-media
# STORAGE_S3_ENDPOINT=https://s3.amazonaws.com
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=TU_ACCESS_KEY
# STORAGE_S3_SECRET_KEY=TU_SECRET_KEY

# ──── n8n ────
N8N_WEBHOOK_URL=http://n8n:5678
N8N_IMAGE_GEN_WEBHOOK=/webhook/image-generation
N8N_PUBLISH_WEBHOOK=/webhook/auto-publish

# ──── AI APIs ────
GEMINI_API_KEY=tu-api-key-de-gemini
OPENAI_API_KEY=tu-api-key-de-openai
OPENROUTER_API_KEY=tu-api-key-de-openrouter

# ──── Meta (Facebook/Instagram) ────
META_APP_ID=tu-meta-app-id
META_APP_SECRET=tu-meta-app-secret
META_REDIRECT_URI=http://localhost:8000/api/social/meta/callback

# ──── Redis ────
REDIS_URL=redis://redis:6379/0
