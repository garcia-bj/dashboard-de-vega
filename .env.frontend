# URL publica del backend (la que el navegador del usuario usa para llamar a la API)
# - Mismo servidor con dominio: https://api.TU_DOMINIO.com
# - Mismo servidor sin dominio: http://IP_DEL_SERVIDOR:8000
# - Servidor separado: https://api.TU_DOMINIO.com o http://IP_BACKEND:8000
NEXT_PUBLIC_API_URL=https://api.TU_DOMINIO.com
